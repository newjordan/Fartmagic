ARM_DESC="V1.6 Longworm fast L8: 8L x 480d, heads 12/kv4, taps on, hybrid k2/k4(last_n=1), non-ngram, brotli"

# Long-context lane.
TRAIN_SEQ_LEN=2048
EVAL_SEQ_LEN=2048
EVAL_STRIDE=64
TRAIN_BATCH_TOKENS=131072
VAL_BATCH_SIZE=131072
BIGRAM_VOCAB_SIZE=4096
BIGRAM_DIM=192
TRIGRAM=1

# Keep n-gram eval off for this lane.
NGRAM_EVAL_ORDER=0
NGRAM_EVAL_ALPHA=0.0
NGRAM_EVAL_ADAPTIVE=0
CUBRIC_CADENCE=0

# Schedule + optimizer tuned for 10-minute cap.
WARMUP_STEPS=144
WARMDOWN_ITERS=3200
LATE_QAT_THRESHOLD=0.24
MATRIX_LR=0.029
SCALAR_LR=0.025

# Capacity geometry (FA3-safe: model_dim multiple of heads*8 => 96).
MODEL_DIM=480
NUM_LAYERS=8
NUM_HEADS=12
NUM_KV_HEADS=4
MLP_MULT=3.25
XSA_LAST_N=4

# Transition strategy: keep RK signal but confine cost.
TRANSITION_INTEGRATOR=hybrid_k2_k4
TRANSITION_HYBRID_LAST_N=1

# Longworm context mechanism.
LONGCTX_TAPS_ENABLED=1
LONGCTX_TAP_OFFSETS=16,64,256,1024
LONGCTX_TAP_PREFIX_MEAN=1
LONGCTX_TAP_NORM=1
LONGCTX_TAP_LOGIT_INIT=-2.2
LONGCTX_TAP_SCALE_INIT=0.06
LONGCTX_PREFIX_LOGIT_INIT=-2.0

# Quant policy.
QUANT_ATTN_BITS=6
QUANT_MLP_BITS=7
QUANT_AUX_BITS=7
QUANT_EMBED_BITS=8
QUANT_OTHER_BITS=8
