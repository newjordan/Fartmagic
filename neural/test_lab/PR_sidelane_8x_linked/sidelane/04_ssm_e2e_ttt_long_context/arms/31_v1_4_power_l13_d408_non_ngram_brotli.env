ARM_DESC="V1.4 Longworm power control: 13L x 408d, higher MLR, legal non-ngram, brotli"

# Keep long-context lane.
TRAIN_SEQ_LEN=2048
EVAL_SEQ_LEN=2048
EVAL_STRIDE=64
TRAIN_BATCH_TOKENS=196608
VAL_BATCH_SIZE=131072
BIGRAM_VOCAB_SIZE=4096
BIGRAM_DIM=192
TRIGRAM=1

# Legal guard: disable n-gram evaluation path.
NGRAM_EVAL_ORDER=0
NGRAM_EVAL_ALPHA=0.0
NGRAM_EVAL_ADAPTIVE=0
CUBRIC_CADENCE=0

# Schedule + optimizer retuned for stronger per-step learning under 10-minute cap.
WARMUP_STEPS=320
WARMDOWN_ITERS=3800
LATE_QAT_THRESHOLD=0.22
MATRIX_LR=0.026
SCALAR_LR=0.024

# Capacity increase.
MODEL_DIM=408
NUM_LAYERS=13
MLP_MULT=3.25

# Keep proven low-penalty quant policy.
QUANT_ATTN_BITS=6
QUANT_MLP_BITS=7
QUANT_AUX_BITS=7
QUANT_EMBED_BITS=8
QUANT_OTHER_BITS=8
