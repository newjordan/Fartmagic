ARM_DESC="V1.4 Longworm candidate: 11L x 480d, heads 12/kv4, non-ngram, brotli"

# Long-context lane.
TRAIN_SEQ_LEN=2048
EVAL_SEQ_LEN=2048
EVAL_STRIDE=64
TRAIN_BATCH_TOKENS=131072
VAL_BATCH_SIZE=131072
BIGRAM_VOCAB_SIZE=4096
BIGRAM_DIM=192
TRIGRAM=1

# Keep n-gram eval off for this lane.
NGRAM_EVAL_ORDER=0
NGRAM_EVAL_ALPHA=0.0
NGRAM_EVAL_ADAPTIVE=0
CUBRIC_CADENCE=0

# Schedule + optimizer tuned for 10-minute cap.
WARMUP_STEPS=320
WARMDOWN_ITERS=3800
LATE_QAT_THRESHOLD=0.24
MATRIX_LR=0.027
SCALAR_LR=0.024

# Capacity shift: less depth, more width + denser heads.
# NOTE: with heads=12 and FA3, model_dim must be a multiple of 96.
MODEL_DIM=480
NUM_LAYERS=11
NUM_HEADS=12
NUM_KV_HEADS=4
MLP_MULT=3.25

# Quant policy.
QUANT_ATTN_BITS=6
QUANT_MLP_BITS=7
QUANT_AUX_BITS=7
QUANT_EMBED_BITS=8
QUANT_OTHER_BITS=8
