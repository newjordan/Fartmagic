ARM_DESC="V1.5 Longworm context-mech: 11L x 480d, heads 12/kv4, multi-scale taps + hybrid RK, non-ngram, brotli"

# Long-context lane.
TRAIN_SEQ_LEN=2048
EVAL_SEQ_LEN=2048
EVAL_STRIDE=64
TRAIN_BATCH_TOKENS=131072
VAL_BATCH_SIZE=131072
BIGRAM_VOCAB_SIZE=4096
BIGRAM_DIM=192
TRIGRAM=1

# Keep n-gram eval off for this lane.
NGRAM_EVAL_ORDER=0
NGRAM_EVAL_ALPHA=0.0
NGRAM_EVAL_ADAPTIVE=0
CUBRIC_CADENCE=0

# Schedule + optimizer tuned for 10-minute cap.
WARMUP_STEPS=320
WARMDOWN_ITERS=3800
LATE_QAT_THRESHOLD=0.24
MATRIX_LR=0.028
SCALAR_LR=0.025

# Capacity: less generic depth pressure, keep width.
# NOTE: with heads=12 and FA3, model_dim must be a multiple of 96.
MODEL_DIM=480
NUM_LAYERS=11
NUM_HEADS=12
NUM_KV_HEADS=4
MLP_MULT=3.25
XSA_LAST_N=5

# Transition strategy.
TRANSITION_INTEGRATOR=hybrid_k2_k4
TRANSITION_HYBRID_LAST_N=4

# Longworm context mechanism (dedicated trainer path).
LONGCTX_TAPS_ENABLED=1
LONGCTX_TAP_OFFSETS=16,64,256,1024
LONGCTX_TAP_PREFIX_MEAN=1
LONGCTX_TAP_NORM=1
LONGCTX_TAP_LOGIT_INIT=-2.2
LONGCTX_TAP_SCALE_INIT=0.06
LONGCTX_PREFIX_LOGIT_INIT=-2.0

# Quant policy.
QUANT_ATTN_BITS=6
QUANT_MLP_BITS=7
QUANT_AUX_BITS=7
QUANT_EMBED_BITS=8
QUANT_OTHER_BITS=8
