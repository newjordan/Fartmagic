ARM_DESC="V1.2 submission test: long-context densehash candidate with non-ngram eval and brotli artifact"

# Architecture lane (same long-context densehash family, tuned for learning quality).
TRAIN_SEQ_LEN=2048
EVAL_SEQ_LEN=2048
EVAL_STRIDE=64
TRAIN_BATCH_TOKENS=131072
VAL_BATCH_SIZE=131072
BIGRAM_VOCAB_SIZE=4096
BIGRAM_DIM=192
TRIGRAM=1

# Legal guard: disable n-gram evaluation path.
NGRAM_EVAL_ORDER=0
NGRAM_EVAL_ALPHA=0.0
NGRAM_EVAL_ADAPTIVE=0
CUBRIC_CADENCE=0

# Learning-quality overrides for 8xH100 competition profile.
WARMUP_STEPS=128
LATE_QAT_THRESHOLD=0
MLP_MULT=3.5
MATRIX_LR=0.03
SCALAR_LR=0.03

# Spend available size headroom to reduce post-quant quality loss.
QUANT_ATTN_BITS=6
QUANT_MLP_BITS=7
QUANT_AUX_BITS=7
QUANT_EMBED_BITS=8
QUANT_OTHER_BITS=8
