ARM_DESC="V1.3 depth arm: deeper stack (12 layers), long-context densehash, legal non-ngram"

# Keep long-context lane.
TRAIN_SEQ_LEN=2048
EVAL_SEQ_LEN=2048
EVAL_STRIDE=64
TRAIN_BATCH_TOKENS=131072
VAL_BATCH_SIZE=131072
BIGRAM_VOCAB_SIZE=4096
BIGRAM_DIM=192
TRIGRAM=1

# Legal guard: disable n-gram evaluation path.
NGRAM_EVAL_ORDER=0
NGRAM_EVAL_ALPHA=0.0
NGRAM_EVAL_ADAPTIVE=0
CUBRIC_CADENCE=0

# Schedule + optimizer changes tuned for 10-minute wallclock.
WARMUP_STEPS=256
WARMDOWN_ITERS=3000
LATE_QAT_THRESHOLD=0.18
MATRIX_LR=0.024
SCALAR_LR=0.022

# Increase true depth (trainer uses NUM_LAYERS).
MODEL_DIM=384
NUM_LAYERS=12
MLP_MULT=3.0

# Use size headroom vs earlier baseline while staying safely under cap.
QUANT_ATTN_BITS=6
QUANT_MLP_BITS=7
QUANT_AUX_BITS=7
QUANT_EMBED_BITS=8
QUANT_OTHER_BITS=8
