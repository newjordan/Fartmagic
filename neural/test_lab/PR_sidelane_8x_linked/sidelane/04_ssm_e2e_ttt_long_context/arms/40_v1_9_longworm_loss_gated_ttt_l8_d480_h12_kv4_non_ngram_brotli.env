ARM_DESC="V1.9.1 Longworm loss-gated TTT: adaptive chunk steps (1..2) with safer thresholding, SSM+TTT L8 480d, non-ngram, brotli"

# 1x H100 lane tuned for 10-minute submission profile.
TRAIN_SEQ_LEN=2048
EVAL_SEQ_LEN=2048
EVAL_STRIDE=64
TRAIN_BATCH_TOKENS=32768
VAL_BATCH_SIZE=65536
BIGRAM_VOCAB_SIZE=4096
BIGRAM_DIM=192
TRIGRAM=1

# Keep n-gram eval off for this lane.
NGRAM_EVAL_ORDER=0
NGRAM_EVAL_ALPHA=0.0
NGRAM_EVAL_ADAPTIVE=0
CUBRIC_CADENCE=0

# Schedule + optimizer.
WARMUP_STEPS=64
WARMDOWN_ITERS=2400
LATE_QAT_THRESHOLD=0.24
MATRIX_LR=0.028
SCALAR_LR=0.025

# Capacity geometry.
MODEL_DIM=480
NUM_LAYERS=8
NUM_HEADS=12
NUM_KV_HEADS=4
MLP_MULT=3.0
XSA_LAST_N=3

TRANSITION_INTEGRATOR=euler

# Longworm context taps.
LONGCTX_TAPS_ENABLED=1
LONGCTX_TAP_OFFSETS=16,64,256,1024
LONGCTX_TAP_PREFIX_MEAN=1
LONGCTX_TAP_NORM=1
LONGCTX_TAP_LOGIT_INIT=-2.2
LONGCTX_TAP_SCALE_INIT=0.06
LONGCTX_PREFIX_LOGIT_INIT=-2.0

# State-space + end-to-end TTT.
SSM_ENABLED=1
SSM_LAST_N=4
SSM_STATE_DIM=96
SSM_DECAY_INIT=0.92
SSM_SCALE_INIT=0.07

TTT_ENABLED=1
TTT_LAST_N=2
TTT_RANK=64
TTT_CHUNK_SIZE=64
TTT_STEPS=1
TTT_LR_INIT=0.12
TTT_SCALE_INIT=0.04
TTT_DETACH_TARGET=1

# Adaptive test-time compute (loss-gated).
TTT_ADAPTIVE_ENABLED=1
TTT_ADAPTIVE_MIN_STEPS=1
TTT_ADAPTIVE_MAX_STEPS=2
TTT_ADAPTIVE_ERR_LOW=0.012
TTT_ADAPTIVE_ERR_HIGH=0.060
TTT_ADAPTIVE_EMA_DECAY=0.95
TTT_DRIFT_ENABLED=0

# Safety clamps for fast-weight updates.
TTT_UPDATE_CLAMP=1.0
TTT_WEIGHT_CLAMP=6.0

# Quant policy.
QUANT_ATTN_BITS=6
QUANT_MLP_BITS=7
QUANT_AUX_BITS=7
QUANT_EMBED_BITS=8
QUANT_OTHER_BITS=8
